{
    "name": "sse-postgres-server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "start": "bun src/index.ts",
        "build": "bun build src/index.ts --outdir dist --target bun --sourcemap=external",
        "typecheck": "bunx tsc --noEmit",
        "lint": "eslint src --ext .ts",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "pino": "^9.7.0",
        "postgres": "^3.4.8"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/bun": "latest",
        "@types/node": "^24.3.0",
        "@types/pino": "^7.0.5",
        "eslint": "^9.0.0",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.0.0",
        "vitest": "^3.2.4"
    }
}